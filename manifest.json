{
  "manifest_version": 3,
  "name": "Offramp",
  "version": "1.0.0",
  "description": "An exit from the endless scroll. Blocks short-form video feeds and any site you name.",
  "permissions": ["declarativeNetRequest", "storage"],
  "action": { "default_popup": "popup.html", "default_title": "Offramp" },
  "host_permissions": [
    "*://*.youtube.com/*",
    "*://*.instagram.com/*",
    "*://*.tiktok.com/*",
    "*://*.facebook.com/*"
  ],
  "declarative_net_request": {
    "rule_resources": [
      { "id": "rules", "enabled": true, "path": "rules.json" }
    ]
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.youtube.com/*",
        "*://*.instagram.com/*",
        "*://*.facebook.com/*"
      ],
      "js": ["dist/block.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["blocked.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
